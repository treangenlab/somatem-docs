        initqc[Read QC \n NanoPlot]
        trimming[Filter/Trim \n chopper]  
        dehost[Remove host \n hostile]
        finalqc[Clean QC \n NanoPlot]
        
        cleaned[CLEAN READS]
        initqc -->|taxp,taxp_16S,func,asm,rhea| trimming

