        finalqc -->|taxp,taxp_16S,func,asm,rhea| cleaned
    end

    subgraph assembly [Assembly]
        %%metro direction: TB
        %%metro entry: left | asm
        %%metro exit: bottom | asm
        denovo[Assemble \n metaFlye]
        %%  refguided["Reference-guided<br>(MetaCompass)"]
        binning[Bin \n Semibin2]
        genomeqc[Genome QC \n CheckM2]
        annotation[Annotate \n Bakta]
        genomemap[circos plot]
        %% contigs[contigs]

        denovo -->|asm| binning
        binning -->|asm| genomeqc
        genomeqc -->|asm| annotation
        annotation -->|asm| genomemap

